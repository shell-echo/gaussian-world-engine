{
  "format": "splat-world",
  "version": 1,
  "name": "Butterfly Proxy Lab",
  "spawn": {
    "position": [0, 0.05, 4.2],
    "yawDeg": 0
  },
  "environment": {
    "background": "#090b10",
    "fogNear": 45,
    "fogFar": 120
  },
  "splats": [
    {
      "id": "butterfly",
      "url": "https://sparkjs.dev/assets/splats/butterfly.spz",
