      "behavior": { "mode": "solid" },
      "body": { "mode": "fixed" },
      "interactable": {
        "prompt": "检查 Mesh Ramp",
        "event": "demo:inspect-ramp",
        "message": "这个斜坡由 Rapier TriMesh 提供碰撞",
        "maxDistance": 3.5
      }
    }
  ]
