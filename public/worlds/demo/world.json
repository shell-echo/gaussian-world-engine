      "scale": 1.45,
      "lod": true
    }
  ],
  "colliders": [
    {
      "id": "floor",
      "type": "box",
      "position": [0, -0.25, 0],
      "size": [18, 0.5, 18],
      "behavior": { "mode": "solid" },
      "body": { "mode": "fixed" }
    },
    {
      "id": "north-wall",
      "type": "box",
      "position": [0, 2.25, -8.75],
      "size": [18, 4.5, 0.5],
      "behavior": { "mode": "solid" },
      "body": { "mode": "fixed" }
    },
    {
      "id": "south-wall",
      "type": "box",
      "position": [0, 2.25, 8.75],
      "size": [18, 4.5, 0.5],
      "behavior": { "mode": "solid" },
      "body": { "mode": "fixed" }
    },
    {
      "id": "west-wall",
      "type": "box",
      "position": [-8.75, 2.25, 0],
      "size": [0.5, 4.5, 18],
      "behavior": { "mode": "solid" },
      "body": { "mode": "fixed" }
    },
    {
      "id": "east-wall",
      "type": "box",
      "position": [8.75, 2.25, 0],
      "size": [0.5, 4.5, 18],
      "behavior": { "mode": "solid" },
      "body": { "mode": "fixed" }
    },
    {
      "id": "welcome-trigger",
      "type": "box",
      "position": [0, 1, 2],
      "size": [3.2, 2, 2.5],
      "behavior": {
        "mode": "trigger",
        "event": "demo:welcome",
        "message": "你进入了 Gaussian World 的触发区域",
        "once": true
      },
      "body": { "mode": "fixed" }
    },
    {
      "id": "dynamic-crate",
      "type": "box",
      "position": [0.7, 3.2, -0.6],
      "rotationDeg": [8, 12, 4],
      "size": [0.85, 0.85, 0.85],
      "behavior": { "mode": "solid" },
      "body": {
        "mode": "dynamic",
        "gravityScale": 1,
        "linearDamping": 0.12,
        "angularDamping": 0.2
      },
      "interactable": {
        "prompt": "检查动态箱体",
        "event": "demo:inspect-crate",
        "message": "这个 Box 由 Rapier 动态刚体驱动",
        "maxDistance": 3.5
      }
    },
    {
      "id": "dynamic-convex-rock",
      "type": "convex",
      "position": [-0.8, 4.4, -1.4],
      "rotationDeg": [15, 25, 8],
      "scale3": [0.8, 0.8, 0.8],
      "vertices": [
        [-0.8, -0.5, -0.6],
        [0.7, -0.6, -0.5],
        [0.8, -0.4, 0.6],
        [-0.6, -0.5, 0.8],
        [-0.4, 0.7, -0.3],
        [0.5, 0.8, 0.2],
        [0.1, 0.3, 0.9]
      ],
      "sourceName": "procedural-rock",
      "behavior": { "mode": "solid" },
      "body": {
        "mode": "dynamic",
        "gravityScale": 1,
        "linearDamping": 0.1,
        "angularDamping": 0.18
      }
    },
    {
      "id": "capsule-pillar",
      "type": "capsule",
      "position": [-2.2, 1.35, -0.8],
      "rotationDeg": [0, 0, 0],
      "radius": 0.45,
      "halfHeight": 0.9,
      "behavior": { "mode": "solid" },
      "body": { "mode": "fixed" },
      "interactable": {
        "prompt": "检查 Capsule 柱体",
        "event": "demo:inspect-pillar",
        "message": "这是一个带 Interactable 组件的 Capsule Collider",
        "maxDistance": 3.5
      }
    },
    {
      "id": "mesh-ramp",
      "type": "mesh",
      "position": [1.7, 0, -1.4],
      "rotationDeg": [0, -20, 0],
      "scale3": [1.1, 0.8, 1.1],
