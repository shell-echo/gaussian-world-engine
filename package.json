{
  "name": "splat-world-engine",
  "version": "0.31.0",
  "private": true,
  "type": "module",
  "bin": {
    "swe-builder": "./bin/swe-builder.js"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview --host 0.0.0.0",
    "builder": "node ./dist-builder/tools/swe-builder/cli.js",
    "builder:build": "tsc -p tsconfig.builder.json",
    "builder:typecheck": "tsc -p tsconfig.builder.json --noEmit --pretty false"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.18.2",
    "@sparkjsdev/spark": "2.1.0",
    "three": "0.180.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/three": "0.180.0",
    "typescript": "5.7.3",
    "vite": "8.0.16"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
